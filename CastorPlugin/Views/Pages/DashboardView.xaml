<Page
  x:Class="CastorPlugin.Views.Pages.DashboardView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="clr-namespace:CastorPlugin.ViewModels.Pages"
  xmlns:converters="clr-namespace:CastorPlugin.ViewModels.Converters"
  xmlns:wui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
  Title="Dashboard"
  d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
  mc:Ignorable="d"
  Background="{DynamicResource ApplicationBackgroundBrush}">

  <Page.Resources>
    <converters:BoolVisibilityConverter x:Key="BoolToVisConverter" />
    <converters:InverseBoolVisibilityConverter x:Key="InverseBoolToVisConverter" />

    <!-- Color Palette -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#6366F1"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#4F46E5"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="#F8FAFC"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="#1E293B"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="#64748B"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#E2E8F0"/>

    <!-- Button Style -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="24,12"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}"
                    BorderThickness="0">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="#CBD5E1"/>
                <Setter Property="Foreground" Value="#94A3B8"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Card Style -->
    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="20"/>
      <Setter Property="Margin" Value="0,0,0,16"/>
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Direction="270"/>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Icon Text Style -->
    <Style x:Key="IconTextStyle" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets, Segoe UI Symbol"/>
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Margin" Value="0,0,12,0"/>
    </Style>
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
    <StackPanel MaxWidth="800">

      <!-- Header -->
      <TextBlock Text="挖宝大厅"
                 FontSize="28"
                 FontWeight="Bold"
                 Foreground="{StaticResource TextPrimaryBrush}"
                 Margin="0,0,0,24"/>

      <!-- 登录状态卡片 -->
      <Border Style="{StaticResource CardStyle}">
        <Grid>
          <!-- 未登录状态 -->
          <StackPanel Orientation="Horizontal"
                      Visibility="{Binding IsLoggedIn, Converter={StaticResource InverseBoolToVisConverter}}">
            <TextBlock Text="&#xE8D4;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource WarningBrush}"/>
            <TextBlock Text="请先登录以使用挖宝功能" VerticalAlignment="Center" FontSize="15" Foreground="{StaticResource TextSecondaryBrush}"/>
            <Button Content="登 录"
                    Command="{Binding ShowLoginCommand}"
                    Style="{StaticResource PrimaryButtonStyle}"
                    Margin="24,0,0,0"
                    Padding="20,10"/>
          </StackPanel>

          <!-- 已登录状态 -->
          <StackPanel Orientation="Horizontal"
                      Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisConverter}}">
            <TextBlock Text="&#xE8FB;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource SuccessBrush}"/>
            <StackPanel Orientation="Vertical" VerticalAlignment="Center">
              <TextBlock Text="已登录" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
              <TextBlock Text="{Binding UserPhone}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
            </StackPanel>
            <Button Content="注销"
                    Command="{Binding LogoutCommand}"
                    Margin="24,0,0,0"
                    Padding="16,8"
                    Background="#FEE2E2"
                    Foreground="#DC2626"
                    BorderThickness="0"
                    Cursor="Hand">
              <Button.Template>
                <ControlTemplate TargetType="Button">
                  <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                </ControlTemplate>
              </Button.Template>
            </Button>
          </StackPanel>
        </Grid>
      </Border>

      <!-- 挖宝说明卡片 -->
      <Border Style="{StaticResource CardStyle}">
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="&#xE82D;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="挖宝功能说明" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Step 1 -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
              <Border Background="#EEF2FF" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                <TextBlock Text="1" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
              </Border>
              <TextBlock Text="扫描族" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
              <TextBlock Text="自动扫描当前 Revit 项目中的所有可编辑族" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>

            <!-- Step 2 -->
            <StackPanel Grid.Column="1" Margin="0,0,16,0">
              <Border Background="#ECFDF5" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                <TextBlock Text="2" FontSize="24" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
              </Border>
              <TextBlock Text="提取指纹" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
              <TextBlock Text="提取参数、几何、缩略图生成唯一指纹" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>

            <!-- Step 3 -->
            <StackPanel Grid.Column="2">
              <Border Background="#FEF3C7" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                <TextBlock Text="3" FontSize="24" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center"/>
              </Border>
              <TextBlock Text="上传登记" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
              <TextBlock Text="上传到服务器，相似族自动跳过" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- 开始挖宝按钮 -->
      <Button Content="&#xE82D;  开始挖宝"
              Command="{Binding StartDigCommand}"
              IsEnabled="{Binding IsLoggedIn}"
              Style="{StaticResource PrimaryButtonStyle}"
              FontSize="16"
              Height="56"
              Margin="0,8,0,16">
        <Button.ContentTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
              <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
            </StackPanel>
          </DataTemplate>
        </Button.ContentTemplate>
      </Button>

      <!-- 挖宝进度（Digging 时显示） -->
      <Border Style="{StaticResource CardStyle}"
              Visibility="{Binding IsDigging, Converter={StaticResource BoolToVisConverter}}">
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="&#xE895;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource WarningBrush}"/>
            <TextBlock Text="挖宝进行中..." FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>

          <ProgressBar Value="{Binding Progress}"
                       Maximum="100"
                       Height="8"
                       Margin="0,0,0,16"
                       Foreground="{StaticResource PrimaryBrush}"
                       Background="#E2E8F0"/>

          <TextBlock Text="{Binding CurrentFamilyName}"
                     FontSize="13"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     Margin="0,0,0,8"/>

          <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}">
            <Run Text="已处理: "/>
            <Run Text="{Binding ScannedFamilies}"/>
            <Run Text=" 个族"/>
          </TextBlock>

          <Button Content="取消挖宝"
                  Command="{Binding CancelDigCommand}"
                  Margin="0,16,0,0"
                  Padding="16,8"
                  Background="#F1F5F9"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  BorderThickness="0"
                  Cursor="Hand">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </StackPanel>
      </Border>

      <!-- 挖宝结果（HasResult 时显示） -->
      <Border Style="{StaticResource CardStyle}"
              Visibility="{Binding HasResult, Converter={StaticResource BoolToVisConverter}}"
              BorderBrush="{StaticResource SuccessBrush}"
              BorderThickness="1">
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="&#xE73E;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource SuccessBrush}"/>
            <TextBlock Text="挖宝完成！" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
          </StackPanel>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
              <TextBlock Text="{Binding TotalScanned}"
                         FontSize="32"
                         FontWeight="Bold"
                         Foreground="{StaticResource PrimaryBrush}"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="扫描族数"
                         FontSize="12"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- New -->
            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
              <TextBlock Text="{Binding NewRegistered}"
                         FontSize="32"
                         FontWeight="Bold"
                         Foreground="{StaticResource SuccessBrush}"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="新增登记"
                         FontSize="12"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Skipped -->
            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
              <TextBlock Text="{Binding SimilarSkipped}"
                         FontSize="32"
                         FontWeight="Bold"
                         Foreground="{StaticResource WarningBrush}"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="相似跳过"
                         FontSize="12"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         HorizontalAlignment="Center"/>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Footer spacing -->
      <StackPanel Height="40"/>
    </StackPanel>
  </ScrollViewer>
</Page>
