<Page
  x:Class="CastorPlugin.Views.Pages.DashboardView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="clr-namespace:CastorPlugin.ViewModels.Pages"
  xmlns:converters="clr-namespace:CastorPlugin.ViewModels.Converters"
  xmlns:wui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
  d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
  mc:Ignorable="d"
  Background="{DynamicResource ApplicationBackgroundBrush}">

  <Page.Resources>
    <converters:BoolVisibilityConverter x:Key="BoolToVisConverter" />
    <converters:InverseBoolVisibilityConverter x:Key="InverseBoolToVisConverter" />

    <!-- Color Palette -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#6366F1"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#4F46E5"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{DynamicResource ControlFillColorDefault}"/>
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="{DynamicResource ApplicationBackgroundColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextFillColorPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextFillColorSecondary}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource ControlStrokeColorDefault}"/>

    <!-- Button Style -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="24,12"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}"
                    BorderThickness="0">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDisabledBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Card Style -->
    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="20"/>
      <Setter Property="Margin" Value="0,0,0,16"/>
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Direction="270"/>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Icon Text Style -->
    <Style x:Key="IconTextStyle" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets, Segoe UI Symbol"/>
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Margin" Value="0,0,12,0"/>
    </Style>
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
    <StackPanel MaxWidth="800">

      <!-- Header -->
      <Grid Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock Text="挖宝大厅"
                     FontSize="28"
                     FontWeight="Bold"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     Margin="0,0,0,8"/>

          <TextBlock Text="市面上的 BIM 构件去除重复因素约 10 万个，越早登记越容易抢占稀缺构件席位。"
                     FontSize="14"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Column="1"
                VerticalAlignment="Top"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12,8"
                Margin="16,2,0,0">
          <Grid>
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource InverseBoolToVisConverter}}">
              <TextBlock Text="&#xE8D4;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource WarningBrush}" Margin="0,0,8,0"/>
              <TextBlock Text="未登录" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
              <Button Content="登录"
                      Command="{Binding ShowLoginCommand}"
                      Style="{StaticResource PrimaryButtonStyle}"
                      Margin="12,0,0,0"
                      Padding="14,7"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisConverter}}">
              <TextBlock Text="&#xE8FB;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource SuccessBrush}" Margin="0,0,8,0"/>
              <TextBlock Text="{Binding UserPhone}"
                         MaxWidth="140"
                         VerticalAlignment="Center"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         TextTrimming="CharacterEllipsis"/>
              <Button Content="注销"
                      Command="{Binding LogoutCommand}"
                      Margin="12,0,0,0"
                      Padding="12,7"
                      Background="#22DC2626"
                      Foreground="#EF4444"
                      BorderThickness="0"
                      Cursor="Hand">
                <Button.Template>
                  <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                      <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                  </ControlTemplate>
                </Button.Template>
              </Button>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>

      <Border Background="#226366F1"
              BorderBrush="#806366F1"
              BorderThickness="1"
              CornerRadius="8"
              Padding="14"
              Margin="0,0,0,16">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="&#xE946;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,10,0"/>
          <TextBlock Text="挖宝只采集构件类别、关键参数、尺寸几何、材质用途等结构化指纹特征，并上传展示用缩略图；不会上传 .rfa 族文件、Revit 项目文件或其他源模型文件。"
                     Grid.Column="1"
                     FontSize="13"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     TextWrapping="Wrap"/>
        </Grid>
      </Border>

      <!-- 挖宝说明卡片 -->
      <Border Style="{StaticResource CardStyle}">
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="&#xE82D;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="挖宝功能说明" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Step 1 -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
              <Border Background="#226366F1" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                <TextBlock Text="1" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
              </Border>
              <TextBlock Text="扫描构件" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
              <TextBlock Text="只读取当前项目中的必要构件信息，不复制族文件" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>

            <!-- Step 2 -->
            <StackPanel Grid.Column="1" Margin="0,0,16,0">
              <Border Background="#2210B981" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                <TextBlock Text="2" FontSize="24" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
              </Border>
              <TextBlock Text="提取指纹" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
              <TextBlock Text="提取类别、参数、尺寸几何、材质用途等结构化指纹" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>

            <!-- Step 3 -->
            <StackPanel Grid.Column="2">
              <Border Background="#22F59E0B" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                <TextBlock Text="3" FontSize="24" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center"/>
              </Border>
              <TextBlock Text="上传登记" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
              <TextBlock Text="仅上传指纹和展示缩略图，相似构件自动跳过" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- 开始挖宝按钮 -->
      <Button Content="&#xE82D;  开始挖宝"
              Command="{Binding StartDigCommand}"
              IsEnabled="{Binding IsLoggedIn}"
              Style="{StaticResource PrimaryButtonStyle}"
              FontSize="16"
              Height="56"
              Margin="0,8,0,16">
        <Button.ContentTemplate>
          <DataTemplate>
            <StackPanel Orientation="Horizontal">
              <TextBlock Text="&#xE82D;" FontFamily="Segoe MDL2 Assets" FontSize="20" VerticalAlignment="Center" Margin="0,0,12,0"/>
              <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
            </StackPanel>
          </DataTemplate>
        </Button.ContentTemplate>
      </Button>

      <!-- 挖宝进度（Digging 时显示） -->
      <Border Style="{StaticResource CardStyle}"
              Visibility="{Binding IsDigging, Converter={StaticResource BoolToVisConverter}}">
        <Border.Triggers>
          <EventTrigger RoutedEvent="Border.Loaded">
            <BeginStoryboard>
              <Storyboard RepeatBehavior="Forever">
                <DoubleAnimation
                  AutoReverse="True"
                  Storyboard.TargetName="DashboardShovelRotate"
                  Storyboard.TargetProperty="Angle"
                  From="-34"
                  To="20"
                  Duration="0:0:0.55">
                  <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                  </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                  AutoReverse="True"
                  Storyboard.TargetName="DashboardShovelTranslate"
                  Storyboard.TargetProperty="Y"
                  From="-2"
                  To="10"
                  Duration="0:0:0.55">
                  <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                  </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                  AutoReverse="True"
                  Storyboard.TargetName="DashboardGemScale"
                  Storyboard.TargetProperty="ScaleX"
                  From="0.92"
                  To="1.08"
                  Duration="0:0:0.7"/>
                <DoubleAnimation
                  AutoReverse="True"
                  Storyboard.TargetName="DashboardGemScale"
                  Storyboard.TargetProperty="ScaleY"
                  From="0.92"
                  To="1.08"
                  Duration="0:0:0.7"/>
                <DoubleAnimation
                  AutoReverse="True"
                  Storyboard.TargetName="DashboardSparkleOne"
                  Storyboard.TargetProperty="Opacity"
                  From="0.25"
                  To="1"
                  Duration="0:0:0.45"/>
                <DoubleAnimation
                  AutoReverse="True"
                  BeginTime="0:0:0.2"
                  Storyboard.TargetName="DashboardSparkleTwo"
                  Storyboard.TargetProperty="Opacity"
                  From="0.2"
                  To="0.95"
                  Duration="0:0:0.45"/>
              </Storyboard>
            </BeginStoryboard>
          </EventTrigger>
        </Border.Triggers>
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
            <TextBlock Text="&#xE895;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource WarningBrush}"/>
            <TextBlock Text="挖宝进行中..." FontSize="16" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>

          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="220"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border
              Width="210"
              Height="122"
              Background="#1838BDF8"
              BorderBrush="#5538BDF8"
              BorderThickness="1"
              CornerRadius="8">
              <Canvas Width="210" Height="122" ClipToBounds="True">
                <Ellipse
                  Width="150"
                  Height="30"
                  Canvas.Left="34"
                  Canvas.Top="86"
                  Fill="#663B2F2F"/>
                <Ellipse
                  Width="98"
                  Height="18"
                  Canvas.Left="58"
                  Canvas.Top="78"
                  Fill="#996B4F3F"/>

                <Polygon
                  Points="105,34 132,58 120,88 90,88 78,58"
                  Fill="#38BDF8"
                  Stroke="#0EA5E9"
                  StrokeThickness="2"
                  RenderTransformOrigin="0.5,0.65">
                  <Polygon.RenderTransform>
                    <ScaleTransform x:Name="DashboardGemScale" ScaleX="1" ScaleY="1"/>
                  </Polygon.RenderTransform>
                </Polygon>
                <Polygon
                  Points="105,34 118,58 105,88 90,88 78,58"
                  Fill="#7DD3FC"
                  Opacity="0.75"/>
                <Polygon
                  Points="118,58 132,58 120,88 105,88"
                  Fill="#0284C7"
                  Opacity="0.55"/>

                <Ellipse
                  x:Name="DashboardSparkleOne"
                  Width="8"
                  Height="8"
                  Canvas.Left="142"
                  Canvas.Top="34"
                  Fill="#FDE68A"
                  Opacity="0.6"/>
                <Ellipse
                  x:Name="DashboardSparkleTwo"
                  Width="6"
                  Height="6"
                  Canvas.Left="70"
                  Canvas.Top="42"
                  Fill="#A7F3D0"
                  Opacity="0.35"/>
                <Ellipse
                  Width="5"
                  Height="5"
                  Canvas.Left="154"
                  Canvas.Top="70"
                  Fill="#F0FDFA"
                  Opacity="0.7"/>

                <Image
                  Width="72"
                  Height="72"
                  Canvas.Left="18"
                  Canvas.Top="18"
                  RenderOptions.BitmapScalingMode="HighQuality"
                  RenderTransformOrigin="0.82,0.82"
                  Source="pack://application:,,,/CastorPlugin;component/Resources/Images/shovel.png">
                  <Image.RenderTransform>
                    <TransformGroup>
                      <RotateTransform x:Name="DashboardShovelRotate" Angle="-34"/>
                      <TranslateTransform x:Name="DashboardShovelTranslate" Y="0"/>
                    </TransformGroup>
                  </Image.RenderTransform>
                </Image>
              </Canvas>
            </Border>

            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0,0,0">
              <TextBlock
                Text="正在从当前项目里挖掘可登记的构件指纹"
                FontSize="14"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                TextWrapping="Wrap"/>
              <TextBlock
                Margin="0,6,0,0"
                Text="小铲子只搬走参数、尺寸、材质用途和缩略图，不搬走族文件。"
                FontSize="12"
                Foreground="{StaticResource TextSecondaryBrush}"
                TextWrapping="Wrap"/>
            </StackPanel>
          </Grid>

          <ProgressBar Value="{Binding Progress}"
                       Maximum="100"
                       Height="8"
                       Margin="0,0,0,16"
                       Foreground="{StaticResource PrimaryBrush}"
                       Background="{DynamicResource ControlFillColorDefaultBrush}"/>

          <TextBlock Text="{Binding CurrentFamilyName}"
                     FontSize="13"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     Margin="0,0,0,8"/>

          <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}">
            <Run Text="已处理: "/>
            <Run Text="{Binding ScannedFamilies}"/>
            <Run Text=" 个族"/>
          </TextBlock>

          <Button Content="取消挖宝"
                  Command="{Binding CancelDigCommand}"
                  Margin="0,16,0,0"
                  Padding="16,8"
                  Background="{DynamicResource ControlFillColorDefaultBrush}"
                  Foreground="{StaticResource TextPrimaryBrush}"
                  BorderThickness="0"
                  Cursor="Hand">
            <Button.Template>
              <ControlTemplate TargetType="Button">
                <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                  <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
              </ControlTemplate>
            </Button.Template>
          </Button>
        </StackPanel>
      </Border>

      <!-- 挖宝结果（HasResult 时显示） -->
      <Border Style="{StaticResource CardStyle}"
              Visibility="{Binding HasResult, Converter={StaticResource BoolToVisConverter}}"
              BorderBrush="{StaticResource SuccessBrush}"
              BorderThickness="1">
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="&#xE73E;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource SuccessBrush}"/>
            <TextBlock Text="挖宝完成！" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
          </StackPanel>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
              <TextBlock Text="{Binding TotalScanned}"
                         FontSize="32"
                         FontWeight="Bold"
                         Foreground="{StaticResource PrimaryBrush}"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="扫描族数"
                         FontSize="12"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- New -->
            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
              <TextBlock Text="{Binding NewRegistered}"
                         FontSize="32"
                         FontWeight="Bold"
                         Foreground="{StaticResource SuccessBrush}"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="新增登记"
                         FontSize="12"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Skipped -->
            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
              <TextBlock Text="{Binding SimilarSkipped}"
                         FontSize="32"
                         FontWeight="Bold"
                         Foreground="{StaticResource WarningBrush}"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="相似跳过"
                         FontSize="12"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         HorizontalAlignment="Center"/>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Footer spacing -->
      <StackPanel Height="40"/>
    </StackPanel>
  </ScrollViewer>
</Page>
