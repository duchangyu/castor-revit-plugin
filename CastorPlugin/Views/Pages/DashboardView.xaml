<Page
  x:Class="CastorPlugin.Views.Pages.DashboardView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="clr-namespace:CastorPlugin.ViewModels.Pages"
  xmlns:converters="clr-namespace:CastorPlugin.ViewModels.Converters"
  xmlns:wui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
  d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
  mc:Ignorable="d"
  Background="{DynamicResource ApplicationBackgroundBrush}">

  <Page.Resources>
    <converters:BoolVisibilityConverter x:Key="BoolToVisConverter" />
    <converters:InverseBoolVisibilityConverter x:Key="InverseBoolToVisConverter" />

    <!-- Color Palette -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#6366F1"/>
    <SolidColorBrush x:Key="PrimaryHoverBrush" Color="#4F46E5"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="#10B981"/>
    <SolidColorBrush x:Key="WarningBrush" Color="#F59E0B"/>
    <SolidColorBrush x:Key="CardBackgroundBrush" Color="{DynamicResource ControlFillColorDefault}"/>
    <SolidColorBrush x:Key="PageBackgroundBrush" Color="{DynamicResource ApplicationBackgroundColor}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{DynamicResource TextFillColorPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{DynamicResource TextFillColorSecondary}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{DynamicResource ControlStrokeColorDefault}"/>

    <!-- Button Style -->
    <Style x:Key="PrimaryButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource PrimaryBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="24,12"/>
      <Setter Property="Cursor" Value="Hand"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Background="{TemplateBinding Background}"
                    CornerRadius="8"
                    Padding="{TemplateBinding Padding}"
                    BorderThickness="0">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter Property="Background" Value="{StaticResource PrimaryHoverBrush}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter Property="Background" Value="{DynamicResource ControlFillColorDisabledBrush}"/>
                <Setter Property="Foreground" Value="{DynamicResource TextFillColorDisabledBrush}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Card Style -->
    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="20"/>
      <Setter Property="Margin" Value="0,0,0,16"/>
      <Setter Property="Effect">
        <Setter.Value>
          <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.08" Direction="270"/>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Icon Text Style -->
    <Style x:Key="IconTextStyle" TargetType="TextBlock">
      <Setter Property="FontFamily" Value="Segoe MDL2 Assets, Segoe UI Symbol"/>
      <Setter Property="FontSize" Value="20"/>
      <Setter Property="VerticalAlignment" Value="Center"/>
      <Setter Property="Margin" Value="0,0,12,0"/>
    </Style>
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="24">
    <StackPanel MaxWidth="800">

      <!-- Header -->
      <Grid Margin="0,0,0,12">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel>
          <TextBlock Text="挖宝大厅"
                     FontSize="28"
                     FontWeight="Bold"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     Margin="0,0,0,8"/>

          <TextBlock Text="市面上的 BIM 构件去除重复因素约 10 万个，越早登记越容易抢占稀缺构件席位。"
                     FontSize="14"
                     Foreground="{StaticResource TextSecondaryBrush}"
                     TextWrapping="Wrap"/>
        </StackPanel>

        <Border Grid.Column="1"
                VerticalAlignment="Top"
                Background="{DynamicResource ControlFillColorDefaultBrush}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="8"
                Padding="12,8"
                Margin="16,2,0,0">
          <Grid>
            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource InverseBoolToVisConverter}}">
              <TextBlock Text="&#xE8D4;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource WarningBrush}" Margin="0,0,8,0"/>
              <TextBlock Text="未登录" VerticalAlignment="Center" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
              <Button Content="登录"
                      Command="{Binding ShowLoginCommand}"
                      Style="{StaticResource PrimaryButtonStyle}"
                      Margin="12,0,0,0"
                      Padding="14,7"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal"
                        Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisConverter}}">
              <TextBlock Text="&#xE8FB;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource SuccessBrush}" Margin="0,0,8,0"/>
              <TextBlock Text="{Binding UserDisplayName}"
                         MaxWidth="140"
                         VerticalAlignment="Center"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource TextPrimaryBrush}"
                         TextTrimming="CharacterEllipsis"/>
              <Button Content="注销"
                      Command="{Binding LogoutCommand}"
                      Margin="12,0,0,0"
                      Padding="12,7"
                      Background="#22DC2626"
                      Foreground="#EF4444"
                      BorderThickness="0"
                      Cursor="Hand">
                <Button.Template>
                  <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                      <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                  </ControlTemplate>
                </Button.Template>
              </Button>
            </StackPanel>
          </Grid>
        </Border>
      </Grid>

      <Border Background="#226366F1"
              BorderBrush="#806366F1"
              BorderThickness="1"
              CornerRadius="8"
              Padding="14"
              Margin="0,0,0,16">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <TextBlock Text="&#xE946;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource PrimaryBrush}" Margin="0,0,10,0"/>
          <TextBlock Text="挖宝只采集构件类别、关键参数、尺寸几何、材质用途等结构化指纹特征，并上传展示用缩略图；不会上传 .rfa 族文件、Revit 项目文件或其他源模型文件。"
                     Grid.Column="1"
                     FontSize="13"
                     Foreground="{StaticResource TextPrimaryBrush}"
                     TextWrapping="Wrap"/>
        </Grid>
      </Border>

      <!-- 挖宝控制台 -->
      <Border Style="{StaticResource CardStyle}" Padding="0" ClipToBounds="True">
        <Border.Triggers>
          <EventTrigger RoutedEvent="Border.Loaded">
            <BeginStoryboard>
              <Storyboard RepeatBehavior="Forever">
                <DoubleAnimation
                  Storyboard.TargetName="ScannerRingRotate"
                  Storyboard.TargetProperty="Angle"
                  From="0"
                  To="360"
                  Duration="0:0:5"/>
                <DoubleAnimation
                  Storyboard.TargetName="ScanSweepRotate"
                  Storyboard.TargetProperty="Angle"
                  From="0"
                  To="360"
                  Duration="0:0:2.6"/>
                <DoubleAnimation
                  Storyboard.TargetName="OrbitRotate"
                  Storyboard.TargetProperty="Angle"
                  From="360"
                  To="0"
                  Duration="0:0:7"/>
                <DoubleAnimation
                  AutoReverse="True"
                  Storyboard.TargetName="CrystalPulseScale"
                  Storyboard.TargetProperty="ScaleX"
                  From="0.96"
                  To="1.05"
                  Duration="0:0:1.25">
                  <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                  </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                  AutoReverse="True"
                  Storyboard.TargetName="CrystalPulseScale"
                  Storyboard.TargetProperty="ScaleY"
                  From="0.96"
                  To="1.05"
                  Duration="0:0:1.25">
                  <DoubleAnimation.EasingFunction>
                    <SineEase EasingMode="EaseInOut"/>
                  </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                  AutoReverse="True"
                  Storyboard.TargetName="CrystalGlow"
                  Storyboard.TargetProperty="Opacity"
                  From="0.35"
                  To="0.85"
                  Duration="0:0:1.1"/>
                <DoubleAnimation
                  AutoReverse="True"
                  Storyboard.TargetName="ScanLineTranslate"
                  Storyboard.TargetProperty="X"
                  From="-54"
                  To="54"
                  Duration="0:0:1.35">
                  <DoubleAnimation.EasingFunction>
                    <QuadraticEase EasingMode="EaseInOut"/>
                  </DoubleAnimation.EasingFunction>
                </DoubleAnimation>
                <DoubleAnimation
                  AutoReverse="True"
                  Storyboard.TargetName="DataDotOne"
                  Storyboard.TargetProperty="Opacity"
                  From="0.25"
                  To="1"
                  Duration="0:0:0.65"/>
                <DoubleAnimation
                  AutoReverse="True"
                  BeginTime="0:0:0.2"
                  Storyboard.TargetName="DataDotTwo"
                  Storyboard.TargetProperty="Opacity"
                  From="0.2"
                  To="0.95"
                  Duration="0:0:0.7"/>
                <DoubleAnimation
                  AutoReverse="True"
                  BeginTime="0:0:0.38"
                  Storyboard.TargetName="DataDotThree"
                  Storyboard.TargetProperty="Opacity"
                  From="0.25"
                  To="0.9"
                  Duration="0:0:0.75"/>
              </Storyboard>
            </BeginStoryboard>
          </EventTrigger>
        </Border.Triggers>

        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="280"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0"
                  MinHeight="214"
                  Padding="16"
                  CornerRadius="12,0,0,12">
            <Border.Background>
              <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#111827" Offset="0"/>
                <GradientStop Color="#1E1B4B" Offset="0.52"/>
                <GradientStop Color="#0F766E" Offset="1"/>
              </LinearGradientBrush>
            </Border.Background>

            <Canvas Width="248" Height="188" HorizontalAlignment="Center" VerticalAlignment="Center">
              <Ellipse
                Width="190"
                Height="190"
                Canvas.Left="29"
                Canvas.Top="-1"
                Stroke="#2238BDF8"
                StrokeThickness="26"/>
              <Ellipse
                Width="158"
                Height="158"
                Canvas.Left="45"
                Canvas.Top="15"
                Stroke="#55A7F3D0"
                StrokeThickness="1.4"
                StrokeDashArray="8 8"
                RenderTransformOrigin="0.5,0.5">
                <Ellipse.RenderTransform>
                  <RotateTransform x:Name="ScannerRingRotate"/>
                </Ellipse.RenderTransform>
              </Ellipse>
              <Ellipse
                Width="104"
                Height="104"
                Canvas.Left="72"
                Canvas.Top="42"
                Stroke="#334F46E5"
                StrokeThickness="1"/>

              <Path
                Data="M124,94 L124,11 A83,83 0 0 1 181,34 Z"
                Fill="#5538BDF8"
                Opacity="0.72">
                <Path.RenderTransform>
                  <RotateTransform x:Name="ScanSweepRotate" CenterX="124" CenterY="94"/>
                </Path.RenderTransform>
              </Path>

              <Canvas
                Width="188"
                Height="188"
                Canvas.Left="30"
                Canvas.Top="0"
                RenderTransformOrigin="0.5,0.5">
                <Canvas.RenderTransform>
                  <RotateTransform x:Name="OrbitRotate"/>
                </Canvas.RenderTransform>
                <Ellipse x:Name="DataDotOne" Width="9" Height="9" Canvas.Left="89" Canvas.Top="2" Fill="#FDE68A"/>
                <Ellipse x:Name="DataDotTwo" Width="7" Height="7" Canvas.Left="173" Canvas.Top="91" Fill="#A7F3D0" Opacity="0.45"/>
                <Ellipse x:Name="DataDotThree" Width="6" Height="6" Canvas.Left="18" Canvas.Top="139" Fill="#93C5FD" Opacity="0.5"/>
              </Canvas>

              <Ellipse
                x:Name="CrystalGlow"
                Width="96"
                Height="96"
                Canvas.Left="76"
                Canvas.Top="46"
                Fill="#6638BDF8"
                Opacity="0.45"/>

              <Canvas
                Width="86"
                Height="82"
                Canvas.Left="81"
                Canvas.Top="53"
                RenderTransformOrigin="0.5,0.55">
                <Canvas.RenderTransform>
                  <ScaleTransform x:Name="CrystalPulseScale" ScaleX="1" ScaleY="1"/>
                </Canvas.RenderTransform>
                <Polygon Points="43,2 74,25 62,70 24,70 12,25"
                         Stroke="#E0F2FE"
                         StrokeThickness="1.4">
                  <Polygon.Fill>
                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                      <GradientStop Color="#ECFEFF" Offset="0"/>
                      <GradientStop Color="#38BDF8" Offset="0.48"/>
                      <GradientStop Color="#4F46E5" Offset="1"/>
                    </LinearGradientBrush>
                  </Polygon.Fill>
                </Polygon>
                <Polygon Points="43,2 52,25 43,70 24,70 12,25"
                         Fill="#BAE6FD"
                         Opacity="0.72"/>
                <Polygon Points="52,25 74,25 62,70 43,70"
                         Fill="#312E81"
                         Opacity="0.42"/>
                <Polyline Points="12,25 52,25 74,25"
                          Stroke="#F0FDFA"
                          StrokeThickness="1"
                          Opacity="0.7"/>
              </Canvas>

              <Rectangle
                Width="124"
                Height="2"
                Canvas.Left="62"
                Canvas.Top="94"
                RadiusX="1"
                RadiusY="1"
                Fill="#CCF0FDFA">
                <Rectangle.RenderTransform>
                  <TranslateTransform x:Name="ScanLineTranslate"/>
                </Rectangle.RenderTransform>
              </Rectangle>

              <TextBlock
                Text="FINGERPRINT"
                Canvas.Left="71"
                Canvas.Top="160"
                FontSize="11"
                FontWeight="SemiBold"
                Foreground="#A7F3D0"
                Opacity="0.82"/>
            </Canvas>
          </Border>

          <StackPanel Grid.Column="1" Margin="22,20,22,18" VerticalAlignment="Center">
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
              <Border
                Background="#2238BDF8"
                CornerRadius="12"
                Padding="9,4"
                Margin="0,0,8,0"
                Visibility="{Binding IsDigging, Converter={StaticResource BoolToVisConverter}}">
                <TextBlock Text="扫描中" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource PrimaryBrush}"/>
              </Border>
              <Border
                Background="#2210B981"
                CornerRadius="12"
                Padding="9,4"
                Margin="0,0,8,0"
                Visibility="{Binding IsDigging, Converter={StaticResource InverseBoolToVisConverter}}">
                <TextBlock Text="待命" FontSize="12" FontWeight="SemiBold" Foreground="{StaticResource SuccessBrush}"/>
              </Border>
              <TextBlock
                Text="结构化指纹登记"
                FontSize="12"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextSecondaryBrush}"
                VerticalAlignment="Center"/>
            </StackPanel>

            <TextBlock
              Text="构件指纹扫描"
              FontSize="22"
              FontWeight="Bold"
              Foreground="{StaticResource TextPrimaryBrush}"
              Margin="0,0,0,6"/>
            <TextBlock
              Text="从当前 Revit 项目读取类别、关键参数、尺寸几何和材质用途，生成可比对的结构化指纹；不会上传 .rfa、.rvt 或其他源模型文件。"
              FontSize="13"
              LineHeight="20"
              Foreground="{StaticResource TextSecondaryBrush}"
              TextWrapping="Wrap"
              Margin="0,0,0,14"/>

            <StackPanel Visibility="{Binding IsDigging, Converter={StaticResource BoolToVisConverter}}">
              <ProgressBar Value="{Binding Progress}"
                           Maximum="100"
                           Height="8"
                           Foreground="{StaticResource PrimaryBrush}"
                           Background="{DynamicResource ControlFillColorDefaultBrush}"
                           Margin="0,0,0,10"/>

              <TextBlock
                Text="{Binding CurrentFamilyName}"
                FontSize="13"
                FontWeight="SemiBold"
                Foreground="{StaticResource TextPrimaryBrush}"
                TextTrimming="CharacterEllipsis"
                Margin="0,0,0,4"/>

              <TextBlock FontSize="13" Foreground="{StaticResource TextSecondaryBrush}">
                <Run Text="已处理 "/>
                <Run Text="{Binding ScannedFamilies}"/>
                <Run Text=" / "/>
                <Run Text="{Binding TotalFamilies}"/>
                <Run Text=" 个族"/>
              </TextBlock>
            </StackPanel>

            <WrapPanel Visibility="{Binding IsDigging, Converter={StaticResource InverseBoolToVisConverter}}">
              <Border Background="#2238BDF8" CornerRadius="12" Padding="9,5" Margin="0,0,8,8">
                <TextBlock Text="类别" FontSize="12" Foreground="{StaticResource PrimaryBrush}"/>
              </Border>
              <Border Background="#2210B981" CornerRadius="12" Padding="9,5" Margin="0,0,8,8">
                <TextBlock Text="关键参数" FontSize="12" Foreground="{StaticResource SuccessBrush}"/>
              </Border>
              <Border Background="#22F59E0B" CornerRadius="12" Padding="9,5" Margin="0,0,8,8">
                <TextBlock Text="尺寸几何" FontSize="12" Foreground="{StaticResource WarningBrush}"/>
              </Border>
              <Border Background="#2238BDF8" CornerRadius="12" Padding="9,5" Margin="0,0,8,8">
                <TextBlock Text="材质用途" FontSize="12" Foreground="{StaticResource PrimaryBrush}"/>
              </Border>
            </WrapPanel>

            <Grid Margin="0,14,0,0">
              <Button Command="{Binding StartDigCommand}"
                      IsEnabled="{Binding IsLoggedIn}"
                      Style="{StaticResource PrimaryButtonStyle}"
                      Visibility="{Binding IsDigging, Converter={StaticResource InverseBoolToVisConverter}}"
                      HorizontalAlignment="Left"
                      Padding="20,11">
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="18" VerticalAlignment="Center" Margin="0,0,10,0"/>
                  <TextBlock Text="开始挖宝" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>

              <Button Command="{Binding CancelDigCommand}"
                      Visibility="{Binding IsDigging, Converter={StaticResource BoolToVisConverter}}"
                      HorizontalAlignment="Left"
                      Padding="16,9"
                      Background="{DynamicResource ControlFillColorDefaultBrush}"
                      Foreground="{StaticResource TextPrimaryBrush}"
                      BorderThickness="0"
                      Cursor="Hand">
                <Button.Template>
                  <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}" CornerRadius="7" Padding="{TemplateBinding Padding}">
                      <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                  </ControlTemplate>
                </Button.Template>
                <StackPanel Orientation="Horizontal">
                  <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="15" VerticalAlignment="Center" Margin="0,0,8,0"/>
                  <TextBlock Text="取消挖宝" VerticalAlignment="Center"/>
                </StackPanel>
              </Button>
            </Grid>
          </StackPanel>
        </Grid>
      </Border>

      <!-- 挖宝说明卡片 -->
      <Border Style="{StaticResource CardStyle}">
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="&#xE82D;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource PrimaryBrush}"/>
            <TextBlock Text="挖宝功能说明" FontSize="18" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
          </StackPanel>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Step 1 -->
            <StackPanel Grid.Column="0" Margin="0,0,16,0">
              <Border Background="#226366F1" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                <TextBlock Text="1" FontSize="24" FontWeight="Bold" Foreground="{StaticResource PrimaryBrush}" HorizontalAlignment="Center"/>
              </Border>
              <TextBlock Text="扫描构件" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
              <TextBlock Text="只读取当前项目中的必要构件信息，不复制族文件" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>

            <!-- Step 2 -->
            <StackPanel Grid.Column="1" Margin="0,0,16,0">
              <Border Background="#2210B981" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                <TextBlock Text="2" FontSize="24" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" HorizontalAlignment="Center"/>
              </Border>
              <TextBlock Text="提取指纹" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
              <TextBlock Text="提取类别、参数、尺寸几何、材质用途等结构化指纹" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>

            <!-- Step 3 -->
            <StackPanel Grid.Column="2">
              <Border Background="#22F59E0B" CornerRadius="8" Padding="16" Margin="0,0,0,8">
                <TextBlock Text="3" FontSize="24" FontWeight="Bold" Foreground="{StaticResource WarningBrush}" HorizontalAlignment="Center"/>
              </Border>
              <TextBlock Text="上传登记" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" HorizontalAlignment="Center" Margin="0,0,0,4"/>
              <TextBlock Text="仅上传指纹和展示缩略图，相似构件自动跳过" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" TextAlignment="Center"/>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- 挖宝结果（HasResult 时显示） -->
      <Border Style="{StaticResource CardStyle}"
              Visibility="{Binding HasResult, Converter={StaticResource BoolToVisConverter}}"
              BorderBrush="{StaticResource SuccessBrush}"
              BorderThickness="1">
        <StackPanel>
          <StackPanel Orientation="Horizontal" Margin="0,0,0,16">
            <TextBlock Text="&#xE73E;" Style="{StaticResource IconTextStyle}" Foreground="{StaticResource SuccessBrush}"/>
            <TextBlock Text="挖宝完成！" FontSize="18" FontWeight="Bold" Foreground="{StaticResource SuccessBrush}" VerticalAlignment="Center"/>
          </StackPanel>

          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Total -->
            <StackPanel Grid.Column="0" HorizontalAlignment="Center">
              <TextBlock Text="{Binding TotalScanned}"
                         FontSize="32"
                         FontWeight="Bold"
                         Foreground="{StaticResource PrimaryBrush}"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="扫描族数"
                         FontSize="12"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- New -->
            <StackPanel Grid.Column="1" HorizontalAlignment="Center">
              <TextBlock Text="{Binding NewRegistered}"
                         FontSize="32"
                         FontWeight="Bold"
                         Foreground="{StaticResource SuccessBrush}"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="新增登记"
                         FontSize="12"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Skipped -->
            <StackPanel Grid.Column="2" HorizontalAlignment="Center">
              <TextBlock Text="{Binding SimilarSkipped}"
                         FontSize="32"
                         FontWeight="Bold"
                         Foreground="{StaticResource WarningBrush}"
                         HorizontalAlignment="Center"/>
              <TextBlock Text="相似跳过"
                         FontSize="12"
                         Foreground="{StaticResource TextSecondaryBrush}"
                         HorizontalAlignment="Center"/>
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <!-- Footer spacing -->
      <StackPanel Height="40"/>
    </StackPanel>
  </ScrollViewer>
</Page>
