<Page
  x:Class="CastorPlugin.Views.Pages.DashboardView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:vm="clr-namespace:CastorPlugin.ViewModels.Pages"
  xmlns:converters="clr-namespace:CastorPlugin.ViewModels.Converters"
  xmlns:wui="clr-namespace:Wpf.Ui.Controls;assembly=Wpf.Ui"
  Title="Dashboard"
  d:DataContext="{d:DesignInstance Type=vm:DashboardViewModel}"
  mc:Ignorable="d">

  <Page.Resources>
    <converters:BoolVisibilityConverter x:Key="BoolToVisConverter" />
    <converters:InverseBoolVisibilityConverter x:Key="InverseBoolToVisConverter" />
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="20">
    <StackPanel>
      <!-- 登录状态卡片 -->
      <Border Background="#F5F5F5" Padding="15" Margin="0,0,0,15" CornerRadius="5">
        <Grid>
          <!-- 未登录状态 -->
          <StackPanel Orientation="Horizontal"
                      Visibility="{Binding IsLoggedIn, Converter={StaticResource InverseBoolToVisConverter}}">
            <TextBlock Text="请先登录" VerticalAlignment="Center" FontSize="14" Margin="0,0,15,0"/>
            <Button Content="登录" Command="{Binding ShowLoginCommand}" Padding="15,5"/>
          </StackPanel>

          <!-- 已登录状态 -->
          <StackPanel Orientation="Horizontal"
                      Visibility="{Binding IsLoggedIn, Converter={StaticResource BoolToVisConverter}}">
            <TextBlock Text="已登录" VerticalAlignment="Center" FontSize="14" Margin="0,0,10,0"/>
            <TextBlock Text="{Binding UserPhone}" VerticalAlignment="Center" FontWeight="Bold" FontSize="14" Margin="0,0,15,0"/>
            <Button Content="注销" Command="{Binding LogoutCommand}" Padding="15,5"/>
          </StackPanel>
        </Grid>
      </Border>

      <!-- 挖宝说明卡片 -->
      <Border Background="#E3F2FD" Padding="15" Margin="0,0,0,15" CornerRadius="5">
        <StackPanel>
          <TextBlock Text="挖宝说明" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
          <StackPanel Margin="10,0,0,0">
            <TextBlock Text="扫描当前项目中的所有族" Margin="0,0,0,5"/>
            <TextBlock Text="提取参数、几何、缩略图作为指纹" Margin="0,0,0,5"/>
            <TextBlock Text="上传到服务器登记（相似跳过）" Margin="0,0,0,5"/>
          </StackPanel>
        </StackPanel>
      </Border>

      <!-- 开始挖宝按钮 -->
      <Button Content="开始挖宝"
              Command="{Binding StartDigCommand}"
              IsEnabled="{Binding IsLoggedIn}"
              Height="50"
              FontSize="16"
              Margin="0,0,0,15"/>

      <!-- 挖宝进度（Digging 时显示） -->
      <Border Background="#FFF8E1" Padding="15" Margin="0,0,0,15" CornerRadius="5"
              Visibility="{Binding IsDigging, Converter={StaticResource BoolToVisConverter}}">
        <StackPanel>
          <ProgressBar IsIndeterminate="False" Value="{Binding Progress}" Maximum="100" Height="20" Margin="0,0,0,10"/>
          <TextBlock Text="{Binding CurrentFamilyName}" FontSize="12" Foreground="#666"/>
          <TextBlock FontSize="12" Foreground="#666">
            <Run Text="已处理: "/>
            <Run Text="{Binding ScannedFamilies}"/>
            <Run Text=" 个"/>
          </TextBlock>
        </StackPanel>
      </Border>

      <!-- 挖宝结果（HasResult 时显示） -->
      <Border Background="#E8F5E9" Padding="15" CornerRadius="5"
              Visibility="{Binding HasResult, Converter={StaticResource BoolToVisConverter}}">
        <StackPanel>
          <TextBlock Text="扫描完成！" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
          <TextBlock Text="{Binding ResultMessage}" FontSize="14"/>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
